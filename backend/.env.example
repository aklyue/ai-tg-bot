# Telegram Bot Token от @BotFather
TG_BOT_TOKEN=your_telegram_bot_token_here

# Optional proxy for Telegram API from Docker.
# Examples:
# TELEGRAM_PROXY=http://host.docker.internal:7890
# TELEGRAM_PROXY=socks5://host.docker.internal:1080
TELEGRAM_PROXY=

# Soniox API ключ для Speech-to-Text
SONIOX_API_KEY=your_soniox_api_key_here

# Bothub.ru API (OpenAI-совместимый)
OPENAI_API_KEY=your_bothub_api_key_here
OPENAI_BASE_URL=https://bothub.chat/api/v2/openai/v1

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Минимальный score релевантности. Если бот часто говорит "не знаю", снизьте до 0.20-0.25.
MIN_RELEVANCE_SCORE=0.30
